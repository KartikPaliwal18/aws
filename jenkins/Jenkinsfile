pipeline {
    agent any

    environment {
        // Replace 'your-username' if you want a fallback, 
        // but we'll extract it from credentials below.
        IMAGE_NAME = "simple-python-app"
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Build & Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        # Login
                        echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                        
                        # Build and Tag using the username from credentials
                        docker build -t $DOCKER_USER/$IMAGE_NAME:${env.BUILD_NUMBER} .
                        docker tag $DOCKER_USER/$IMAGE_NAME:${env.BUILD_NUMBER} $DOCKER_USER/$IMAGE_NAME:latest
                        
                        # Push both tags
                        docker push $DOCKER_USER/$IMAGE_NAME:${env.BUILD_NUMBER}
                        docker push $DOCKER_USER/$IMAGE_NAME:latest
                    """
                }
            }
        }

        stage('Run Container Locally') {
            steps {
                // Using '|| true' ensures the pipeline doesn't fail if the container doesn't exist yet
                sh """
                    docker stop $IMAGE_NAME || true
                    docker rm $IMAGE_NAME || true
                    docker run -d -p 80:5000 --name $IMAGE_NAME $DOCKER_USER/$IMAGE_NAME:latest
                """
            }
        }
    }
    
    post {
        always {
            sh "docker logout"
        }
    }
}
