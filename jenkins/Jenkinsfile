pipeline {
    agent any

    environment {
        IMAGE_NAME = "simple-python-app"
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Build, Push & Run') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        # 1. Login
                        echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                        
                        # 2. Build and Push (This worked in your logs!)
                        docker build -t $DOCKER_USER/$IMAGE_NAME:${env.BUILD_NUMBER} .
                        docker tag $DOCKER_USER/$IMAGE_NAME:${env.BUILD_NUMBER} $DOCKER_USER/$IMAGE_NAME:latest
                        docker push $DOCKER_USER/$IMAGE_NAME:${env.BUILD_NUMBER}
                        docker push $DOCKER_USER/$IMAGE_NAME:latest
                        
                        # 3. Run Locally (Fix: Use DOCKER_USER while inside this block)
                        docker stop $IMAGE_NAME || true
                        docker rm $IMAGE_NAME || true
                        docker run -d -p 80:5000 --name $IMAGE_NAME $DOCKER_USER/$IMAGE_NAME:latest
                    """
                }
            }
        }
    }

    post {
        always {
            sh "docker logout"
        }
    }
}
